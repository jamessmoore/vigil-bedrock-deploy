{
  "providers": {
    "bedrock": {
      "keys": [
        {
          "name": "bedrock-primary",
          "models": ["*"],
          "weight": 1.0,
          "aliases": {
            "claude-sonnet-4-6": "${bedrock_sonnet_model_id}"
          },
          "bedrock_key_config": {
            "region": "${aws_region}"
          }
        }
      ]
    },
    "anthropic": {
      "keys": [
        {
          "name": "anthropic-fallback",
          "value": "env.ANTHROPIC_API_KEY",
          "models": ["*"],
          "weight": 1.0
        }
      ]
    },
    "openai": {
      "keys": [
        {
          "name": "openai-fallback",
          "value": "env.OPENAI_API_KEY",
          "models": ["*"],
          "weight": 1.0
        }
      ]
    }
  },
  "governance": {
    "routing_rules": [
      {
        "id": "claude-to-bedrock-primary",
        "name": "Claude Sonnet 4.6 -> Bedrock primary, Anthropic/OpenAI fallback",
        "description": "Routes all Claude traffic to AWS Bedrock as the primary provider (SigV4 via the ECS task role, no API key), with Anthropic direct and OpenAI as ordered fallbacks. This is the config-level mechanism that makes Vigil run on Bedrock without any application code change.",
        "enabled": true,
        "cel_expression": "model.startsWith(\"claude\")",
        "targets": [
          { "provider": "bedrock", "model": "claude-sonnet-4-6", "weight": 1.0 }
        ],
        "fallbacks": [
          "anthropic/claude-sonnet-4-6",
          "openai/gpt-4o"
        ],
        "scope": "global",
        "scope_id": null,
        "priority": 0
      }
    ]
  }
}
